export LANG="en_US.UTF-8"

# history
export HISTIGNORE="&:ls:[bf]g:exit"
export HISTSIZE=40000
export HISTFILESIZE=1000000
unsetopt share_history # don't share history between sessions

setopt inc_append_history_time # save the time stamp when the command was entered
setopt interactivecomments # allow comments in interactive shell

# completions (brew site-functions + zsh-completions)
fpath=(/opt/homebrew/share/zsh/site-functions /opt/homebrew/share/zsh-completions $fpath)
# Перестраиваем дамп раз в сутки, иначе грузим готовый кэш (-C) без медленной
# проверки безопасности fpath. glob раскрываем через массив — в [[ -n ]] генерации имён нет.
autoload -Uz compinit
_zcd=${ZDOTDIR:-$HOME}/.zcompdump
_zcd_stale=( $_zcd(N.mh+24) )
if (( $#_zcd_stale )); then
  compinit -u -d "$_zcd"
else
  compinit -C -u -d "$_zcd"
fi
unset _zcd _zcd_stale

# Run 'ls' after 'cd'
autoload -Uz add-zsh-hook
function chpwd_ls {
    ls
}
add-zsh-hook chpwd chpwd_ls

# autojump
if (( $+commands[brew] )); then
  file=$HOMEBREW_PREFIX/etc/profile.d/autojump.sh
  [[ -f "$file" ]] && source "$file"
fi

export PATH="$HOME/.local/bin:$PATH"
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"
export PATH="/opt/homebrew/opt/mysql-client/bin:$PATH"
export CPPFLAGS="-I/opt/homebrew/include"
export LDFLAGS="-L/opt/homebrew/lib"

export HOMEBREW_NO_ENV_HINTS=1
export GPG_TTY=$(tty)

# nx: no cloud prompts, non-interactive
export NX_NO_CLOUD=true
export NX_INTERACTIVE=false

eval "$(starship init zsh)"
eval "$(zoxide init zsh)"
eval "$(atuin init zsh)"

# shell plugins from homebrew — zsh-syntax-highlighting MUST be sourced last
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh
source /opt/homebrew/share/zsh-you-should-use/you-should-use.plugin.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
