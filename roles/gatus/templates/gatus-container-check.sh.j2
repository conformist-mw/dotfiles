#!/usr/bin/env bash
# {{ ansible_managed }} — roles/gatus.
# Report container liveness to Gatus external-endpoints so Gatus can alert
# (Telegram) when a container is down or stuck in a crash-loop. Portless
# containers (e.g. school-bot) can't be polled over HTTP, hence this push.
set -uo pipefail

GATUS="http://127.0.0.1:{{ gatus_push_port }}"
TOKEN="{{ gatus_external_token }}"
GROUP="containers"

push() {
  local name="$1" success="$2" err="$3"
  # -G moves --data-urlencode fields into the query string; -X POST keeps the
  # method Gatus expects. Failures are logged, never fatal (set -e is off).
  curl -fsS -m 10 -X POST -G \
    --data-urlencode "success=${success}" \
    --data-urlencode "error=${err}" \
    -H "Authorization: Bearer ${TOKEN}" \
    "${GATUS}/api/v1/endpoints/${GROUP}_${name}/external" >/dev/null \
    || logger -t gatus-container-check "push failed for ${name}"
}

for c in {{ gatus_watched_containers | join(' ') }}; do
  if ! docker inspect "$c" >/dev/null 2>&1; then
    push "$c" false "container not found"
    continue
  fi
  read -r running restarting health < <(docker inspect \
    -f '{{ '{{.State.Running}} {{.State.Restarting}} {{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' }}' \
    "$c")
  if [[ "$running" == "true" && "$restarting" == "false" && "$health" != "unhealthy" ]]; then
    push "$c" true ""
  else
    push "$c" false "running=${running} restarting=${restarting} health=${health}"
  fi
done
